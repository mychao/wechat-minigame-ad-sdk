{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "dom"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["jest", "node"],
    "typeRoots": ["../types", "./node_modules/@types"]
  },
  "include": [
    "./*.ts",
    "../*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
